# ===========================================================================
# Environment configuration template.
# Copy to ".env" and fill in real values:  cp .env.example .env
# NEVER commit the real .env file (it is git-ignored).
# ===========================================================================

# --- Application -----------------------------------------------------------
APP_NAME="AI Document Intelligence Platform"
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
DEBUG=true

# --- API server ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of origins allowed by CORS (Streamlit dev server).
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# --- Database --------------------------------------------------------------
# SQLite for local dev. Swap for postgresql+psycopg2://user:pass@host:5432/db
DATABASE_URL=sqlite:///./data/app.db

# --- Authentication / JWT --------------------------------------------------
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_dev_only_insecure_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Frontend (Streamlit -> backend) ---------------------------------------
API_BASE_URL=http://localhost:8000

# --- Generative AI (Gemini) ------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- ML / NLP model config -------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2   # sentence-transformers model name
SPACY_MODEL=en_core_web_sm
FAISS_INDEX_PATH=./data/faiss_index
CHURN_MODEL_PATH=./backend/app/ml/artifacts/churn_model.joblib

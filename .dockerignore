# Keep build context small and images clean.
.git
.github
.venv
venv
env
__pycache__
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache

# Local runtime data / secrets (never bake into images).
.env
data/
logs/
**/logs/
backend/app/ml/artifacts/*.joblib

# Docs & editor cruft not needed at runtime.
docs/screenshots/*.png
.vscode
.idea
.DS_Store
